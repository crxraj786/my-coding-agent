#!/bin/bash
# ============================================
# PRE-COMMIT HOOK — SETUP PROTECTION
# ============================================
# This hook runs BEFORE every git commit.
# It BLOCKS any commit that modifies PROTECTED files.
# To override (ONLY when bhai explicitly says to):
#   git commit --no-verify -m "..."
# ============================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# ---- PROTECTED FILES (kabhi modify mat karo) ----
PROTECTED_FILES=(
  ".gitignore"
  ".env.example"
  "SYSTEM_SPECIFICATION.md"
  "README.md"
  "SETUP_FINGERPRINT"
)

# ---- PROTECTED DIRECTORIES (andar kuch bhi modify mat karo) ----
PROTECTED_DIRS=(
  ".github/workflows"
  "scripts"
)

# ---- Check what's being committed ----
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

VIOLATIONS=""

# Check protected files
for file in "${PROTECTED_FILES[@]}"; do
  if echo "$STAGED_FILES" | grep -qxF "$file"; then
    VIOLATIONS="$VIOLATIONS  [FILE]     $file\n"
  fi
done

# Check protected directories
for dir in "${PROTECTED_DIRS[@]}"; do
  while IFS= read -r changed_file; do
    if [ -n "$changed_file" ]; then
      VIOLATIONS="$VIOLATIONS  [DIRECTORY] $changed_file (inside $dir/)\n"
    fi
  done < <(echo "$STAGED_FILES" | grep "^${dir}/" || true)
done

# ---- If violations found, BLOCK the commit ----
if [ -n "$VIOLATIONS" ]; then
  echo -e ""
  echo -e "${RED}============================================================${NC}"
  echo -e "${RED}          SETUP PROTECTION — COMMIT BLOCKED!               ${NC}"
  echo -e "${RED}============================================================${NC}"
  echo -e ""
  echo -e "${RED}  Bhai, yeh PROTECTED setup files modify ho rahi hain:${NC}"
  echo -e ""
  echo -e "$VIOLATIONS"
  echo -e "${RED}------------------------------------------------------------${NC}"
  echo -e "${RED}  YEH SETUP KA SYSTEM HAI — ISSE KHARAB MAT KARO!         ${NC}"
  echo -e "${RED}------------------------------------------------------------${NC}"
  echo -e "${RED}  Kya ho sakta hai agar modify karo:${NC}"
  echo -e "${RED}    → .gitignore change → .env push → SECRETS LEAK          ${NC}"
  echo -e "${RED}    → Workflow change → Auto deploy start ho sakta hai       ${NC}"
  echo -e "${RED}    → Scripts change → Protection system break               ${NC}"
  echo -e "${RED}    → SYSTEM_SPECIFICATION change → Rules lost               ${NC}"
  echo -e ""
  echo -e "${CYAN}  SIRF projects/ folder mein kaam karo — yahi tumhara     ${NC}"
  echo -e "${CYAN}  allowed area hai. Setup files ko touch mat karo.         ${NC}"
  echo -e ""
  echo -e "${YELLOW}  Agar Bhai ne explicitly kaha hai setup change karna,    ${NC}"
  echo -e "${YELLOW}  toh use: git commit --no-verify                         ${NC}"
  echo -e "${RED}============================================================${NC}"
  echo -e ""
  exit 1
fi

echo -e "${GREEN}✅ Setup Protection Check: SAFE — No protected files modified${NC}"
exit 0
